{
  "name": "kavach-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "KAVACH frontend build tooling",
  "scripts": {
    "css:build": "npx tailwindcss -i ./static/css/input.css -o ./static/css/tailwind.css --minify",
    "css:watch": "npx tailwindcss -i ./static/css/input.css -o ./static/css/tailwind.css --watch",
    "build": "npm run css:build"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
