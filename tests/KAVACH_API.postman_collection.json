              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Tokens",
      "item": [
        {
          "name": "Create Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"url\",\n  \"description\": \"Database backup link\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tokens",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens"]
            }
          }
        },
        {
          "name": "List Tokens",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Bulk Create Tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"count\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tokens/bulk",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens", "bulk"]
            }
          }
        },
        {
          "name": "Delete Token",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tokens/{{token_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens", "{{token_id}}"]
            }
          }
        }
      ]
    },
