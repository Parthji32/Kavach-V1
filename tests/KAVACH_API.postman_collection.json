        {
          "name": "Trust Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/trust-device",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "trust-device"]
